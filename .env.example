# ==========================
# NuuB root environment file
# Copy to `.env` and fill values.
# ==========================

# Postgres container/user setup
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=churn_prediction

# Backend DB connection
DB_HOST=db
DB_PORT=5432
DB_NAME=churn_prediction
DB_USER=your_db_user
DB_PASS=your_db_password
DB_ROW_LIMIT=10000

# Model training controls
XGB_TOTAL_TRIALS=10
MLP_TOTAL_EPOCHS=50

# Runtime profile: local | docker | aws | production
ENVIRONMENT=local

# Frontend build profile used by Docker build arg
# local | docker | production
BUILD_MODE=local
