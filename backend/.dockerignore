# Keep Docker context sane while ensuring all runtime/model files are included.
# Do NOT blanket-ignore the whole repo (that can drop required modules/models).

# Python cache / artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Git / editor files
.git/
.gitignore
.DS_Store

# Local environments
.venv/
venv/

# Notebook / temp files
*.ipynb
temp_*
processed_*

# Optional env file (Railway provides env vars)
.env


